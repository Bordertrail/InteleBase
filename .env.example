# Environment variables example
# Copy this file to .env and update values

# Database
KB_DATABASE_URL=postgres://kbuser:kbpass@localhost:5432/knowledgebase

# Redis
KB_REDIS_URL=redis://localhost:6379

# Storage (MinIO)
KB_STORAGE_ENDPOINT=http://localhost:9000
KB_STORAGE_ACCESS_KEY=minioadmin
KB_STORAGE_SECRET_KEY=minioadmin
KB_STORAGE_BUCKET=knowledge-base

# JWT
KB_JWT_SECRET=dev-secret-change-in-production
KB_JWT_ACCESS_TTL=900
KB_JWT_REFRESH_TTL=604800

# Embedding (TEI)
KB_EMBEDDING_URL=http://localhost:3000
KB_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
KB_EMBEDDING_DIM=1024

# LLM (Ollama)
KB_LLM_URL=http://localhost:11434
KB_LLM_MODEL=llama3.1

# Server
KB_SERVER_HOST=127.0.0.1
KB_SERVER_PORT=3000

# Upload
KB_UPLOAD_MAX_SIZE_MB=50

# Chunking
KB_CHUNKING_CHUNK_SIZE=512
KB_CHUNKING_CHUNK_OVERLAP=50

# Logging
RUST_LOG=info,kb_server=debug